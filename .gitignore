# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# …pero .env.example SÍ se sube: documenta qué variables hacen falta (sin valores).
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Archivos grandes que NO van al deploy:
# schedule.db son horarios programados (84MB, no entra en Netlify Functions).
# La app funciona sin él gracias al fallback a la API oficial.
/data/schedule.db

# Datos crudos GTFS (se regeneran con scripts/, no subir)
/data/gtfs_raw/
interior-stops-raw.json

# Intermedios / regenerables del pipeline (NO subir — se reconstruyen con scripts/):
#  - gtfs-metro.db: se fusiona dentro de gtfs-v2.db (que SÍ va)
#  - gtfs.db / .bak: legacy v1, gtfs-v2.db lo reemplaza
#  - interior-edges.json: acumulador del recolector
/data/gtfs-metro.db
/data/gtfs.db
/data/gtfs.db.bak
/data/interior-edges.json

# Locks/journals temporales de SQLite (nunca subir)
*.db-shm
*.db-wal
*.db-journal

# Carpetas de trabajo temporales de los scripts de investigación
/tmp_gtfs/
/tmp_gtfs_latest/
/tmp_nac/
/tmp_work/
/tmp_inspect/
# Snapshot transitorio del merge metro durante la regeneración GTFS (preserve-metro.mjs)
/tmp_metro_snapshot.json

# Carpeta de diseño (vive fuera de ondas/, pero por las dudas)
*Cuándo - Design*
*Cuando - Design*
