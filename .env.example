# ───────────────────────────────────────────────────────────────────────────
# Variables de entorno de Cuándo (ondas).
#
# En LOCAL: copiá este archivo a .env.local y completá los valores (gitignored).
# En PRODUCCIÓN (Netlify): cargalas en Site settings → Environment variables.
#   - Las NEXT_PUBLIC_* viajan al navegador (no secretas).
#   - Las demás son secretas → scope solo "Functions" en Netlify, nunca "Builds".
# ───────────────────────────────────────────────────────────────────────────

# ── API oficial de transporte de Montevideo (OAuth2) — SECRETAS ──
MVD_API_TOKEN_URL=
MVD_API_CLIENT_ID=
MVD_API_CLIENT_SECRET=
MVD_API_BASE=

# Router peatonal OSRM (opcional; default público en el código)
# OSRM_URL=

# ── Supabase ──
# URL del proyecto y anon/publishable key: PÚBLICAS (van al navegador). La
# seguridad la da la RLS de supabase/schema.sql. Sin estas dos, la app corre en
# modo sin-cuenta (favoritos solo en localStorage) — todo sigue funcionando.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role: SECRETA — bypassa toda la RLS. SOLO para el pipeline que carga el
# catálogo (scripts de servidor). NUNCA con prefijo NEXT_PUBLIC_, nunca al cliente.
# En Netlify: scope "Functions" únicamente.
SUPABASE_SERVICE_ROLE_KEY=
